# ================================
# Music Match — Variables DEV (Azure)
# À configurer dans Azure App Service :
# App Service > Configuration > Application settings
# ================================

NODE_ENV=development
PORT=3000

# Base de données DEV
DATABASE_URL=postgresql://mmadmin:DevPassword123!@music-match-db-dev.postgres.database.azure.com:5432/musicmatch?sslmode=require

# Redis — pas encore déployé sur Azure (pas de free tier).
# Le code n'utilise pas encore Redis. À ajouter plus tard
# si besoin (ex: Upstash free tier) — REDIS_URL=...

# Auth
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=musicmatchstorage;...
AZURE_STORAGE_CONTAINER=profile-photos

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://music-match-api-dev.azurewebsites.net/api/auth/spotify/callback

# Deezer OAuth
DEEZER_CLIENT_ID=your_deezer_client_id
DEEZER_CLIENT_SECRET=your_deezer_client_secret

# App
FRONTEND_URL=https://purple-beach-dev.azurestaticapps.net

# Matching
DEFAULT_MATCH_THRESHOLD=0.80
PREMIUM_MATCH_THRESHOLD=0.60
DAILY_MATCH_LIMIT=5
MESSAGE_TTL_HOURS=24
MATCH_EXPIRY_HOURS=48
