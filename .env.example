# ================================
# Music Match — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env dans Git !
# ================================

# Base de données
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/musicmatch

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Deezer OAuth
DEEZER_CLIENT_ID=your_deezer_client_id
DEEZER_CLIENT_SECRET=your_deezer_client_secret
DEEZER_REDIRECT_URI=http://localhost:3000/auth/deezer/callback

# SoundCloud OAuth
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret

# Azure Blob Storage (photos de profil)
AZURE_STORAGE_ACCOUNT=your_storage_account
AZURE_STORAGE_KEY=your_storage_key
AZURE_STORAGE_CONTAINER=profile-photos

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Matching
DEFAULT_MATCH_THRESHOLD=0.80
PREMIUM_MATCH_THRESHOLD=0.60
DAILY_MATCH_LIMIT=5
MESSAGE_TTL_HOURS=24
MATCH_EXPIRY_HOURS=48
