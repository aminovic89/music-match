# ================================
# Music Match — Variables PROD (Azure)
# À configurer dans Azure App Service :
# App Service > Configuration > Application settings
# ================================

NODE_ENV=production
PORT=3000

# Base de données PROD
DATABASE_URL=postgresql://mmadmin:ProdPassword456!@music-match-db-prod.postgres.database.azure.com:5432/musicmatch?sslmode=require

# Redis PROD
REDIS_URL=rediss://:PASSWORD@music-match-redis-prod.redis.cache.windows.net:6380

# Auth — utiliser un secret fort et aléatoire en prod
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET_IN_PROD
JWT_EXPIRES_IN=7d

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=musicmatchstorage;...
AZURE_STORAGE_CONTAINER=profile-photos

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://music-match-api-prod.azurewebsites.net/api/auth/spotify/callback

# Deezer OAuth
DEEZER_CLIENT_ID=your_deezer_client_id
DEEZER_CLIENT_SECRET=your_deezer_client_secret

# App
FRONTEND_URL=https://purple-beach-prod.azurestaticapps.net

# Matching
DEFAULT_MATCH_THRESHOLD=0.80
PREMIUM_MATCH_THRESHOLD=0.60
DAILY_MATCH_LIMIT=5
MESSAGE_TTL_HOURS=24
MATCH_EXPIRY_HOURS=48
